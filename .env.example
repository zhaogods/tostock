# tostock 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ---- 数据库 ----
db_host=127.0.0.1
db_port=3306
db_user=root
db_password=YOUR_DATABASE_PASSWORD_HERE
db_database=test
# db_charset=utf8mb4

# ---- Tushare ----
TUSHARE_TOKEN=YOUR_TUSHARE_TOKEN_HERE

# ---- 东方财富 Cookie（可选，降低反爬风险）----
# EAST_MONEY_COOKIE=
