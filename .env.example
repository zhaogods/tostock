# tostock 环境变量配置模板
# 复制此文件为 .env 并修改相应配置
# cp .env.example .env

# ============================================================
# 数据库配置（根据部署方式二选一）
# ============================================================

# ---- 方式一：Docker Compose 部署（推荐）----
db_host=InStockDbService
db_port=3306
db_user=root
db_password=root
db_database=test

# ---- 方式二：本地开发 / 外部数据库 ----
# 注释上面四行，取消下面注释并填入实际值：
# db_host=127.0.0.1
# db_port=3306
# db_user=root
# db_password=你的数据库密码
# db_database=test

# ---- 数据库字符集（可选，默认 utf8mb4）----
# db_charset=utf8mb4

# ---- Tushare Token ----
TUSHARE_TOKEN=YOUR_TUSHARE_TOKEN_HERE

# ---- 东方财富 Cookie（可选，降低反爬风险）----
# EAST_MONEY_COOKIE=