# tostock 环境变量配置模板
# 复制此文件为 .env 并修改相应配置
# cp .env.example .env

# ============================================================
# 数据库配置（根据部署方式二选一）
# ============================================================

# ---- 方式一：Docker Compose 部署（推荐）----
db_host=InStockDbService
db_port=3306
db_user=root
db_password=root
db_database=test

# ---- 方式二：本地开发 / 外部数据库（取消注释并填入实际值）----
# db_host=127.0.0.1
# db_port=3306
# db_user=root
# db_password=你的数据库密码
# db_database=test

# ---- 数据库字符集（可选，默认 utf8mb4）----
# db_charset=utf8mb4

# ---- MariaDB Root 密码（仅 Docker Compose 部署需要）----
# MYSQL_ROOT_PASSWORD=root

# ============================================================
# API Token
# ============================================================

# Tushare Token（注册地址 https://tushare.pro）
TUSHARE_TOKEN=YOUR_TUSHARE_TOKEN_HERE

# 通达信抢筹 API Token（抢筹数据源，默认已内置）
# TDXW_API_TOKEN=6679f5cadca97d68245a086793fc1bfc0a50b487487c812f

# Tornado Cookie 密钥（Docker 部署时自动生成，本地可留空用默认值）
# Tornado_COOKIE_SECRET=

# ---- 携趣代理 API（可选，用于绕过东方财富 IP 封禁）----
# 完整 API URL，服务商提供什么就填什么，不需要拆参数
# XIEQU_API_URL=http://api.xiequ.cn/VAD/GetIp.aspx?act=get&uid=181189&vkey=1338F4E72282CDFF3126F9D895FC659C&num=5&time=30&plat=1&re=1&type=2&so=1&ow=1&spl=1&addr=&db=1

# 东方财富 Cookie（可选，降低反爬风险）
# EAST_MONEY_COOKIE=

# ============================================================
# Web 服务
# ============================================================
# WEB_PORT=9988

# ============================================================
# HTTP 请求参数
# ============================================================
# HTTP_RETRY_TOTAL=3
# HTTP_RETRY_BACKOFF=0.1
# Tushare 频率限制（2000积分，官方限额见注释，建议留20%冗余）
# TUSHARE_DAILY_RATE=400          # 官方 500/min
# TUSHARE_DAILY_BASIC_RATE=150    # 官方 200/min
# TUSHARE_MONEYFLOW_RATE=150      # 官方 200/min
# TUSHARE_STOCK_BASIC_RATE=40     # 官方 50/min

# HTTP_TIMEOUT_GET=10
# HTTP_TIMEOUT_POST=60
# HTTP_POOL_CONNS=50
# HTTP_POOL_MAXSIZE=50
# HTTP_RETRY_SLEEP_MIN=1
# HTTP_RETRY_SLEEP_MAX=3

# ============================================================
# 作业调度
# ============================================================
# JOB_BATCH_DELAY=2
# JOB_WORKERS=40
# STOCK_WORKERS=16