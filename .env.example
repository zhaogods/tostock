# tostock 环境变量配置模板
# 复制此文件为 .env 并修改相应配置
# cp .env.example .env

# ============================================================
# 数据库配置
# ============================================================

# ---- 使用远程数据库（推荐用于生产）----
# 配置远程数据库后，本地 MariaDB 容器将不会启动
# 使用方式：删除或重命名 docker-compose.override.yml 文件
db_host=your_remote_db_host
db_port=3306
db_user=your_db_user
db_password=your_db_password
db_database=tostock

# ---- 使用本地 Docker 数据库（开发环境）----
# 保留 docker-compose.override.yml 文件，并配置以下参数：
# db_host=InStockDbService
# db_port=3306
# db_user=root
# db_password=root
# db_database=test
# MYSQL_ROOT_PASSWORD=root

# ---- 数据库字符集（可选，默认 utf8mb4）----
# db_charset=utf8mb4

# ============================================================
# API Token
# ============================================================

# Tushare Token（注册地址 https://tushare.pro）
TUSHARE_TOKEN=YOUR_TUSHARE_TOKEN_HERE

# 通达信抢筹 API Token（抢筹数据源，默认已内置）
# TDXW_API_TOKEN=6679f5cadca97d68245a086793fc1bfc0a50b487487c812f

# Tornado Cookie 密钥（Docker 部署时自动生成，本地可留空用默认值）
# Tornado_COOKIE_SECRET=

# ---- 携趣代理 API（可选，用于绕过东方财富 IP 封禁）----
# 完整 API URL，服务商提供什么就填什么，不需要拆参数
# XIEQU_API_URL=http://api.xiequ.cn/VAD/GetIp.aspx?act=get&uid=181189&vkey=1338F4E72282CDFF3126F9D895FC659C&num=5&time=30&plat=1&re=1&type=2&so=1&ow=1&spl=1&addr=&db=1

# 东方财富 Cookie（可选，降低反爬风险）
# EAST_MONEY_COOKIE=

# ============================================================
# Web 服务
# ============================================================
# WEB_PORT=9988

# ============================================================
# HTTP 请求参数
# ============================================================
# HTTP_RETRY_TOTAL=3
# HTTP_RETRY_BACKOFF=0.1
# Tushare 频率限制（容器内全局限速，scheduler 与手工回填共享同一预算）
# 2000积分官方限额见注释，建议留20%冗余；回填期间不要贴近官方上限。
TUSHARE_DAILY_RATE=400          # 官方 500/min，日线行情
TUSHARE_HIST_BAR_RATE=180       # 历史前复权K线，pro_bar可能内部组合复权请求
TUSHARE_DAILY_BASIC_RATE=150    # 官方 200/min，日指标/换手率
TUSHARE_MONEYFLOW_RATE=150      # 官方 200/min
TUSHARE_STOCK_BASIC_RATE=40     # 官方 50/min
TUSHARE_FINA_INDICATOR_RATE=160 # 官方 200/min，财务指标接口
TUSHARE_DIVIDEND_RATE=120       # 官方 150/min，分红配送接口
TUSHARE_BLOCK_TRADE_RATE=120    # 官方 150/min，大宗交易接口
TUSHARE_RATE_LIMIT=180          # 批量历史缓存每分钟批次数，官方 200/min
TUSHARE_RETRY_TOTAL=5           # 遇到频率超限后的重试次数
TUSHARE_RETRY_SLEEP_SECONDS=60  # 每次频率超限重试前等待秒数
TUSHARE_RATE_LOG_WAIT_SECONDS=5 # 全局限流等待超过该秒数时输出日志

# HTTP_TIMEOUT_GET=10
# HTTP_TIMEOUT_POST=60
# HTTP_POOL_CONNS=50
# HTTP_POOL_MAXSIZE=50
# HTTP_RETRY_SLEEP_MIN=1
# HTTP_RETRY_SLEEP_MAX=3

# ============================================================
# 作业调度
# ============================================================
# JOB_BATCH_DELAY=2          # 日期任务提交间隔秒数
# JOB_DATE_WORKERS=1         # 日期范围回填默认串行，避免放大 API 请求
# HIST_LOOKBACK_DAYS=550     # 历史K线窗口自然日，覆盖MA250并保留缓冲
# BACKTEST_LOOKBACK_DAYS=0   # 回测从信号日前回看天数，0表示从信号日开始
# INDICATOR_CALC_THRESHOLD=250 # 单日指标计算窗口，需>=200保证ma200有效
# STOCK_WORKERS=4            # 历史 K 线加载线程数
# BACKTEST_STOCK_WORKERS=4   # 回测历史 K 线加载线程数
# BACKTEST_CHECK_WORKERS=40  # 回测收益计算线程数（本地计算为主）
# BACKTEST_TABLE_WORKERS=4   # 回测策略表并行数
